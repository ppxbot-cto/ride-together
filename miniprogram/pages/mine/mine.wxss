/* pages/mine/mine.wxss */

.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.login-btn {
  width: 200rpx;
}

.tab-bar {
  display: flex;
  background-color: #ffffff;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  color: #07c160;
  font-weight: 600;
  border-bottom-color: #07c160;
}

.activity-list {
  padding-bottom: 40rpx;
}

.activity-card {
  transition: all 0.2s;
}

.activity-card:active {
  transform: scale(0.98);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #999;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-info {
  margin-bottom: 20rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.participants-count {
  font-size: 26rpx;
  color: #999;
}

.status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-active {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-completed {
  background-color: #f5f5f5;
  color: #999;
}

.status-cancelled {
  background-color: #ffebee;
  color: #f44336;
}
