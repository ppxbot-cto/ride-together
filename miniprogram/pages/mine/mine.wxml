<!--pages/mine/mine.wxml-->
<view class="container">
  <!-- 未登录：显示登录按钮 -->
  <view class="user-section card" wx:if="{{!userInfo}}">
    <view class="login-btn-wrap">
      <button class="login-main-btn" bindtap="tapLogin">微信登录</button>
      <text class="login-hint">登录后可发布活动、加入活动、查看我的活动</text>
    </view>
  </view>

  <!-- 已登录：显示头像与昵称（仅来自微信，不可修改） -->
  <view class="user-section card" wx:else>
    <view class="profile-block">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}"></image>
      <view class="user-avatar placeholder" wx:else>骑</view>
      <text class="user-name-display">{{userInfo.nickName || '骑友'}}</text>
      <text class="logout-btn" bindtap="logout">退出登录</text>
    </view>
  </view>

  <!-- 登录弹窗：getUserProfile 失败时仅可选头像，昵称使用「骑友」 -->
  <view class="login-sheet-mask" wx:if="{{showLoginSheet}}" catchtap="closeLoginSheet">
    <view class="login-sheet" catchtap="">
      <view class="login-sheet-title">设置头像</view>
      <view class="login-sheet-desc">用于在活动中展示你的身份，昵称以微信为准</view>
      <button class="login-sheet-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onLoginSheetChooseAvatar">
        <image class="login-sheet-avatar" src="{{loginForm.avatarPath}}" mode="aspectFill" wx:if="{{loginForm.avatarPath}}"></image>
        <view class="login-sheet-avatar placeholder" wx:else>头像</view>
      </button>
      <view class="login-sheet-actions">
        <button class="login-sheet-cancel" bindtap="closeLoginSheet">取消</button>
        <button class="login-sheet-confirm" bindtap="confirmLoginSheet">确认登录</button>
      </view>
    </view>
  </view>

  <!-- Tab 切换（已登录才显示） -->
  <view class="tab-bar" wx:if="{{userInfo}}">
    <view 
      class="tab-item {{activeTab === 'published' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="published"
    >
      我发布的
    </view>
    <view 
      class="tab-item {{activeTab === 'joined' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="joined"
    >
      我加入的
    </view>
  </view>

  <!-- 未登录时提示 -->
  <view class="activity-list need-login-tip" wx:if="{{!userInfo}}">
    <text class="empty-icon">🔐</text>
    <text>请先点击上方「微信登录」后再使用</text>
  </view>

  <!-- 活动列表（已登录） -->
  <view class="activity-list" wx:else>
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{activities.length === 0}}" class="empty">
      <text class="empty-icon">📭</text>
      <text>{{activeTab === 'published' ? '还没有发布过活动' : '还没有加入过活动'}}</text>
    </view>

    <view wx:else>
      <view 
        wx:for="{{activities}}" 
        wx:key="_id" 
        class="activity-card card"
        bindtap="goDetail"
        data-id="{{item._id}}"
      >
        <view class="activity-header">
          <view class="activity-type tag tag-{{item.type}}">
            {{item.type === 'motorcycle' ? '🏍️ 摩托车' : '🚴 自行车'}}
          </view>
          <text class="activity-time">{{item.meetTime}}</text>
        </view>

        <view class="activity-title">{{item.title}}</view>

        <view class="activity-info">
          <text class="info-item">📍 {{item.meetLocation}}</text>
        </view>

        <view class="activity-footer">
          <text class="participants-count">👥 {{item.participants.length}}/{{item.maxParticipants}}</text>
          <text wx:if="{{activeTab === 'published'}}" class="status-badge status-{{item.status}}">
            {{item.status === 'active' ? '进行中' : (item.status === 'completed' ? '已结束' : '已取消')}}
          </text>
        </view>
      </view>
    </view>
  </view>
</view>
