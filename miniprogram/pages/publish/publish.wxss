/* pages/publish/publish.wxss */

.publish-form {
  padding: 40rpx;
}

.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  padding: 30rpx;
  text-align: center;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s;
}

.type-option.active {
  border-color: #07c160;
  background-color: #f0fff4;
  color: #07c160;
  font-weight: 500;
}

.picker-value {
  color: #333;
}

.textarea {
  min-height: 160rpx;
  padding: 20rpx;
}

.qrcode-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.qrcode-upload {
  margin-top: 8rpx;
}

.qrcode-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  background: #fafafa;
}

.qrcode-btn-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.qrcode-btn-text {
  font-size: 28rpx;
  color: #666;
}

.qrcode-preview {
  position: relative;
  display: inline-block;
}

.qrcode-img {
  display: block;
  width: 240rpx;
  height: 240rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.qrcode-remove {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #07c160;
  padding: 8rpx 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 0 0 12rpx 12rpx;
}

.submit-btn {
  margin-top: 60rpx;
  width: 100%;
}
