/* pages/publish/publish.wxss */

.publish-form {
  padding: 40rpx;
}

.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  padding: 30rpx;
  text-align: center;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s;
}

.type-option.active {
  border-color: #07c160;
  background-color: #f0fff4;
  color: #07c160;
  font-weight: 500;
}

.picker-value {
  color: #333;
}

.textarea {
  min-height: 160rpx;
  padding: 20rpx;
}

.submit-btn {
  margin-top: 60rpx;
  width: 100%;
}
